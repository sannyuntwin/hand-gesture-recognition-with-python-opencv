{
  "detection": {
    "confidence": 0.7,
    "tracking_confidence": 0.7,
    "max_hands": 2
  },
  "gestures": {
    "smoothing_window": 5,
    "hold_time": 1.0,
    "enable_sound": true
  },
  "mouse_control": {
    "sensitivity": 1.5,
    "smooth_factor": 0.3,
    "enable_drag": true
  },
  "volume_control": {
    "step": 0.05,
    "enable_system_control": false
  },
  "presentation": {
    "next_gesture": "Peace",
    "previous_gesture": "Call_Me",
    "pause_gesture": "Palm"
  },
  "accessibility": {
    "high_contrast_ui": false,
    "large_text": false,
    "audio_feedback": false
  },
  "data": {
    "save_sessions": true,
    "save_gestures": true,
    "output_file": "gesture_session.json"
  }
}
